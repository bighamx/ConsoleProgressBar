<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net45;netstandard2.0;net8.0</TargetFrameworks>
    <LangVersion>12.0</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>disable</Nullable>

    <!-- NuGet Package Metadata -->
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <PackageId>Chuckie.ConsoleProgressBar</PackageId>
    <Version>1.0.4</Version>
    <Authors>Chuckie</Authors>
    <Company>Chuckie</Company>
    <Description>An easy-to-use and beautiful console progress bar library for .NET.</Description>
    <RepositoryUrl>https://github.com/bighamx/ConsoleProgressBar</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <ProjectUrl>https://github.com/bighamx/ConsoleProgressBar</ProjectUrl>
    <PackageTags>console;progress;progressbar</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
